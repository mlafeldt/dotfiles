#!/usr/bin/env python3
# Print unresolved Claude incidents and their updates.

import datetime
import json
import sys
import urllib.error
import urllib.request


STATUS_INCIDENTS_URL = "https://status.claude.com/api/v2/incidents/unresolved.json"

USE_COLOR = sys.stdout.isatty()
BOLD = "\033[1m" if USE_COLOR else ""
YELLOW = "\033[33m" if USE_COLOR else ""
DIM = "\033[2m" if USE_COLOR else ""
RESET = "\033[0m" if USE_COLOR else ""


def collapse_whitespace(value: str) -> str:
    return " ".join(value.split())


def parse_hhmm_utc(value: str) -> str:
    if not value:
        return ""

    try:
        dt = datetime.datetime.fromisoformat(value.replace("Z", "+00:00"))
    except ValueError:
        if len(value) >= 16 and value[10] == "T":
            return value[11:16]
        return ""

    return dt.strftime("%H:%M")


def incident_link(incident: dict) -> str:
    shortlink = (incident.get("shortlink") or "").strip()
    if shortlink:
        return shortlink

    incident_id = (incident.get("id") or "").strip()
    if incident_id:
        return f"https://status.claude.com/incidents/{incident_id}"

    return ""


def format_incident(incident: dict) -> str:
    name = (incident.get("name") or "").strip()
    link = incident_link(incident)
    updates = incident.get("incident_updates") or []

    if name and link:
        header = f"{name} - {link}"
    elif name:
        header = name
    elif link:
        header = link
    else:
        return ""

    lines = [header]
    for update in updates:
        body = collapse_whitespace(update.get("body") or "")
        hhmm = parse_hhmm_utc(
            update.get("display_at") or update.get("created_at") or ""
        )

        if body:
            if hhmm:
                lines.append(f"  - {hhmm} UTC: {body}")
            else:
                lines.append(f"  - {body}")

    return "\n".join(lines)


def main() -> int:
    try:
        with urllib.request.urlopen(STATUS_INCIDENTS_URL, timeout=10) as response:
            payload_raw = response.read().decode("utf-8")
    except urllib.error.URLError:
        print(
            f"Unable to fetch Claude status incidents API: {STATUS_INCIDENTS_URL}",
            file=sys.stderr,
        )
        return 1

    if not payload_raw.strip():
        print(
            f"Unable to fetch Claude status incidents API: {STATUS_INCIDENTS_URL}",
            file=sys.stderr,
        )
        return 1

    try:
        payload = json.loads(payload_raw)
    except json.JSONDecodeError:
        print(
            f"Unable to parse Claude status incidents API: {STATUS_INCIDENTS_URL}",
            file=sys.stderr,
        )
        return 1

    incidents = payload.get("incidents") or []
    formatted_incidents = []

    for incident in incidents:
        formatted_incident = format_incident(incident)
        if formatted_incident:
            formatted_incidents.append(formatted_incident)

    if not formatted_incidents:
        print(f"{DIM}No unresolved Claude incidents.{RESET}")
        return 0

    n = len(formatted_incidents)
    s = "s" if n != 1 else ""
    print(f"{YELLOW}{BOLD}{n} unresolved Claude incident{s}!{RESET}")
    print()
    for index, incident in enumerate(formatted_incidents):
        for i, line in enumerate(incident.splitlines()):
            if i == 0:
                print(f"{YELLOW}{line}{RESET}")
            else:
                print(f"{DIM}{line}{RESET}")
        if index < len(formatted_incidents) - 1:
            print()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
